# ══════════════════════════════════════════════════════════════
# AureaIA — Variáveis de Ambiente (exemplo)
# ══════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores reais.
# cp .env.example .env

# ─── Flask ─────────────────────────────────────────────────
FLASK_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
SECRET_KEY=
PORT=5005

# ─── Banco de Dados (Supabase PostgreSQL) ──────────────────
DATABASE_URL=postgresql://user:password@host:6543/postgres
DIRECT_URL=postgresql://user:password@host:6543/postgres

# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── IA (Replicate) ─────────────────────────────────────────
AI_PROVIDER_API_TOKEN=r8_your_token_here
AI_MODEL_ID=openai/gpt-image-2

# ─── Asaas ──────────────────────────────────────────────────
ASAAS_API_KEY=$aact_prod_your_production_key_here
ASAAS_WALLET_ID=your_wallet_id_here
ASAAS_SANDBOX=False
ASAAS_WEBHOOK_TOKEN=whsec_your_webhook_token_here
BACKEND_URL=https://aurea-ai-ftqa.onrender.com
FRONTEND_URL=https://aureaia-saas.vercel.app

# ─── Email (Brevo) ─────────────────────────────────────────
BREVO_API_KEY=CHANGE_ME_your_brevo_api_key
BREVO_SENDER_EMAIL=contato@aureaia.com
BREVO_SENDER_NAME=AureaIA

# ─── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5005/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

