# ══════════════════════════════════════════════════════════════
# Configurações de Ambiente - AureaIA (Backend)
# ══════════════════════════════════════════════════════════════

# Ambiente (development | production)
FLASK_ENV=development

# CORS: Lista separada por vírgulas de origens permitidas
# Em produção: https://aureaia.com,https://www.aureaia.com
# Em desenvolvimento: http://localhost:3000,http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Segurança
SECRET_KEY=generate_a_long_random_string_here
ADMIN_SECRET_KEY=generate_another_random_string_here

# API Keys
REPLICATE_API_TOKEN=

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=contato@aureaia.com
EMAIL_FROM_NAME=AureaIA

